<?xml version="1.0" encoding="UTF-8"?>
<!--
  Custom setup wizard chain, fully localized at runtime:
    Welcome -> Language -> [Google Cloud SDK] -> Shortcuts -> Google API
    (informational; automated on first launch / Skip with warning) ->
    Resolution -> VerifyReady -> progress -> exit.

  No dialog contains literal text: every visible string is a [P_*] property
  filled by the ApplyUiLanguage CA (i18n_ui.js, generated by
  gen_i18n_ui.py) for the language in OUTPUT_LANGUAGE. DetectLanguage seeds
  OUTPUT_LANGUAGE from the machine language before the first dialog, so even
  the Welcome page appears localized; changing the combo re-applies.

  Welcome/VerifyReady/Progress/Exit/Cancel/Maintenance dialogs are authored
  here (the WixUI stock ones have English baked in). Rare error dialogs
  (ErrorDlg, FatalError, UserExit, FilesInUse) remain the stock English ones.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <UI Id="MyOverlayWizard">
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Small" FaceName="Tahoma" Size="7" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />
      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />


      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />

      <!-- fresh-install chain -->
      <Publish Dialog="MyWelcomeDlg" Control="Next" Event="NewDialog" Value="LanguageDlg">1</Publish>

      <Publish Dialog="LanguageDlg" Control="Back" Event="DoAction" Value="ApplyUiLanguage" Order="1">1</Publish>
      <Publish Dialog="LanguageDlg" Control="Back" Event="NewDialog" Value="MyWelcomeDlg" Order="2">1</Publish>
      <!-- Re-translate everything downstream of the combo, then continue
           (skipping the SDK page when the SDK is already on the machine). -->
      <Publish Dialog="LanguageDlg" Control="Next" Event="DoAction" Value="ApplyUiLanguage" Order="1">1</Publish>
      <Publish Dialog="LanguageDlg" Control="Next" Event="NewDialog" Value="ShortcutsDlg" Order="2">GCLOUD_PRESENT</Publish>
      <Publish Dialog="LanguageDlg" Control="Next" Event="NewDialog" Value="GCloudDlg" Order="3">NOT GCLOUD_PRESENT</Publish>

      <!-- Google Cloud SDK page (only shown when the SDK is missing): the
           bundled SDK is set up silently during the install phase, behind the
           progress bar. Informational - just continue. -->
      <Publish Dialog="GCloudDlg" Control="Back" Event="NewDialog" Value="LanguageDlg">1</Publish>
      <Publish Dialog="GCloudDlg" Control="Next" Event="NewDialog" Value="ShortcutsDlg">1</Publish>

      <Publish Dialog="ShortcutsDlg" Control="Back" Event="NewDialog" Value="LanguageDlg" Order="1">GCLOUD_PRESENT</Publish>
      <Publish Dialog="ShortcutsDlg" Control="Back" Event="NewDialog" Value="GCloudDlg" Order="2">NOT GCLOUD_PRESENT</Publish>
      <Publish Dialog="ShortcutsDlg" Control="Next" Event="NewDialog" Value="GoogleDlg">1</Publish>

      <!-- Google page is informational: the configuration runs automatically
           on first launch (one browser sign-in). Next just records the opt-in
           (GOOGLE_SKIPPED=0); Skip routes through the warning page. -->
      <Publish Dialog="GoogleDlg" Control="Back" Event="NewDialog" Value="ShortcutsDlg">1</Publish>
      <Publish Dialog="GoogleDlg" Control="SkipBtn" Event="NewDialog" Value="GoogleSkipWarnDlg">1</Publish>
      <Publish Dialog="GoogleDlg" Control="Next" Property="GOOGLE_SKIPPED" Value="0" Order="1">1</Publish>
      <Publish Dialog="GoogleDlg" Control="Next" Event="NewDialog" Value="ResolutionDlg" Order="2">1</Publish>

      <Publish Dialog="GoogleSkipWarnDlg" Control="Back" Event="NewDialog" Value="GoogleDlg">1</Publish>
      <Publish Dialog="GoogleSkipWarnDlg" Control="SkipAnywayBtn" Property="GOOGLE_SKIPPED" Value="1" Order="1">1</Publish>
      <Publish Dialog="GoogleSkipWarnDlg" Control="SkipAnywayBtn" Event="NewDialog" Value="ResolutionDlg" Order="2">1</Publish>

      <Publish Dialog="ResolutionDlg" Control="Back" Event="NewDialog" Value="GoogleSkipWarnDlg">GOOGLE_SKIPPED = "1"</Publish>
      <Publish Dialog="ResolutionDlg" Control="Back" Event="NewDialog" Value="GoogleDlg">GOOGLE_SKIPPED &lt;&gt; "1"</Publish>
      <Publish Dialog="ResolutionDlg" Control="Next" Event="NewDialog" Value="MyVerifyReadyDlg">1</Publish>

      <Publish Dialog="MyVerifyReadyDlg" Control="Back" Event="NewDialog" Value="ResolutionDlg">1</Publish>
      <Publish Dialog="MyVerifyReadyDlg" Control="Install" Event="EndDialog" Value="Return">1</Publish>

      <!-- maintenance (repair / remove) -->
      <Publish Dialog="MyMaintWelcomeDlg" Control="Next" Event="NewDialog" Value="MyMaintTypeDlg">1</Publish>
      <Publish Dialog="MyMaintTypeDlg" Control="Back" Event="NewDialog" Value="MyMaintWelcomeDlg">1</Publish>
      <Publish Dialog="MyMaintTypeDlg" Control="RepairButton" Event="NewDialog" Value="MyVerifyRepairDlg">1</Publish>
      <Publish Dialog="MyMaintTypeDlg" Control="RemoveButton" Event="NewDialog" Value="RemoveOptionsDlg">1</Publish>

      <Publish Dialog="RemoveOptionsDlg" Control="Back" Event="NewDialog" Value="MyMaintTypeDlg">1</Publish>
      <Publish Dialog="RemoveOptionsDlg" Control="Next" Event="NewDialog" Value="MyVerifyRemoveDlg">1</Publish>

      <Publish Dialog="MyVerifyRemoveDlg" Control="Back" Event="NewDialog" Value="RemoveOptionsDlg">1</Publish>
      <Publish Dialog="MyVerifyRemoveDlg" Control="Remove" Event="Remove" Value="All" Order="1">1</Publish>
      <Publish Dialog="MyVerifyRemoveDlg" Control="Remove" Event="EndDialog" Value="Return" Order="2">1</Publish>

      <Publish Dialog="MyVerifyRepairDlg" Control="Back" Event="NewDialog" Value="MyMaintTypeDlg">1</Publish>
      <Publish Dialog="MyVerifyRepairDlg" Control="Repair" Event="ReinstallMode" Value="ecmus" Order="1">1</Publish>
      <Publish Dialog="MyVerifyRepairDlg" Control="Repair" Event="Reinstall" Value="All" Order="2">1</Publish>
      <Publish Dialog="MyVerifyRepairDlg" Control="Repair" Event="EndDialog" Value="Return" Order="3">1</Publish>

      <Publish Dialog="MyExitDlg" Control="Finish" Event="EndDialog" Value="Return">1</Publish>

      <!-- ______________ Welcome ______________ -->
      <Dialog Id="MyWelcomeDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="Bitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="234" TabSkip="no" Text="WixUI_Bmp_Dialog" />
        <Control Id="Title" Type="Text" X="135" Y="20" Width="220" Height="60" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Bigger}[P_WELCOME_TITLE]" />
        <Control Id="Description" Type="Text" X="135" Y="80" Width="220" Height="60" Transparent="yes" NoPrefix="yes" Text="[P_WELCOME_DESC]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Disabled="yes" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Language ______________ -->
      <Dialog Id="LanguageDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_LANG_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="[P_LANG_DESC]" />
        <Control Id="Explain" Type="Text" X="25" Y="60" Width="320" Height="40" NoPrefix="yes" Text="[P_LANG_EXPLAIN]" />
        <Control Id="LangLabel" Type="Text" X="25" Y="106" Width="100" Height="12" NoPrefix="yes" Text="[P_LANG_LABEL]" />
        <Control Id="LangCombo" Type="ComboBox" X="25" Y="120" Width="180" Height="16" Property="OUTPUT_LANGUAGE" ComboList="yes" Sorted="no">
          <ComboBox Property="OUTPUT_LANGUAGE">
            <ListItem Text="English" Value="en" />
            <ListItem Text="Portuguese (Português)" Value="pt" />
            <ListItem Text="Spanish (Español)" Value="es" />
            <ListItem Text="Japanese" Value="ja" />
            <ListItem Text="Arabic" Value="ar" />
            <ListItem Text="French (Français)" Value="fr" />
            <ListItem Text="Italian (Italiano)" Value="it" />
            <ListItem Text="Russian" Value="ru" />
            <ListItem Text="Chinese, Simplified" Value="zh" />
          </ComboBox>
        </Control>
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Google Cloud SDK ______________ -->
      <Dialog Id="GCloudDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_GC_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="[P_GC_DESC]" />
        <Control Id="Explain" Type="Text" X="25" Y="56" Width="320" Height="96" NoPrefix="yes" Text="[P_GC_EXPLAIN]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Shortcuts ______________ -->
      <Dialog Id="ShortcutsDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_SC_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="[P_SC_DESC]" />
        <Control Id="StartMenuCheck" Type="CheckBox" X="25" Y="70" Width="320" Height="17" Property="STARTMENU_SHORTCUT" CheckBoxValue="1" Text="[P_SC_START]" />
        <Control Id="DesktopCheck" Type="CheckBox" X="25" Y="92" Width="320" Height="17" Property="DESKTOP_SHORTCUT" CheckBoxValue="1" Text="[P_SC_DESKTOP]" />
        <Control Id="Note" Type="Text" X="25" Y="120" Width="320" Height="24" NoPrefix="yes" Text="[P_SC_NOTE]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Google API setup ______________ -->
      <Dialog Id="GoogleDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="290" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_GA_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="330" Height="15" Transparent="yes" NoPrefix="yes" Text="[P_GA_DESC]" />
        <Control Id="WhatHdr" Type="Text" X="25" Y="48" Width="330" Height="12" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_GA_WHAT_H]" />
        <Control Id="WhatText" Type="Text" X="25" Y="61" Width="330" Height="52" NoPrefix="yes" Text="[P_GA_WHAT]" />
        <Control Id="WhyHdr" Type="Text" X="25" Y="116" Width="330" Height="12" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_GA_WHY_H]" />
        <Control Id="WhyText" Type="Text" X="25" Y="129" Width="330" Height="24" NoPrefix="yes" Text="[P_GA_WHY]" />
        <Control Id="NextHdr" Type="Text" X="25" Y="156" Width="330" Height="12" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_GA_NEXT_H]" />
        <Control Id="NextText" Type="Text" X="25" Y="169" Width="330" Height="28" NoPrefix="yes" Text="[P_GA_NEXT]" />
        <Control Id="SkipBtn" Type="PushButton" X="25" Y="202" Width="130" Height="18" Text="[P_SKIPBTN]" />
        <Control Id="SkipNote" Type="Text" X="162" Y="205" Width="196" Height="20" NoPrefix="yes" Text="{\WixUI_Font_Small}[P_GA_SKIPNOTE]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Skip warning ______________ -->
      <Dialog Id="GoogleSkipWarnDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="290" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_SW_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="330" Height="15" Transparent="yes" NoPrefix="yes" Text="[P_SW_DESC]" />
        <Control Id="WarnText" Type="Text" X="25" Y="60" Width="320" Height="110" NoPrefix="yes" Text="[P_SW_TEXT]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="156" Y="243" Width="80" Height="17" Text="[P_BACK]" />
        <Control Id="SkipAnywayBtn" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="[P_SKIPANYWAY]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Resolution ______________ -->
      <Dialog Id="ResolutionDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_RES_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="[P_RES_DESC]" />
        <Control Id="Explain" Type="Text" X="25" Y="60" Width="320" Height="40" NoPrefix="yes" Text="[P_RES_EXPLAIN]" />
        <Control Id="ResLabel" Type="Text" X="25" Y="106" Width="100" Height="12" NoPrefix="yes" Text="[P_RES_LABEL]" />
        <Control Id="ResCombo" Type="ComboBox" X="25" Y="120" Width="180" Height="16" Property="RESOLUTION" ComboList="yes" Sorted="no">
          <ComboBox Property="RESOLUTION">
            <ListItem Text="hd (720p)" Value="hd" />
            <ListItem Text="fhd (1080p)" Value="fhd" />
            <ListItem Text="2k (1440p)" Value="2k" />
            <ListItem Text="4k (2160p)" Value="4k" />
          </ComboBox>
        </Control>
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Verify ready (install) ______________ -->
      <Dialog Id="MyVerifyReadyDlg" Width="370" Height="270" Title="[ProductName]" TrackDiskSpace="yes">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_VR_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="60" Width="320" Height="40" NoPrefix="yes" Text="[P_VR_DESC]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Install" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" ElevationShield="yes" Text="[P_INSTALL]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Verify remove ______________ -->
      <Dialog Id="MyVerifyRemoveDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_VRM_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="60" Width="320" Height="40" NoPrefix="yes" Text="[P_VRM_DESC]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Remove" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" ElevationShield="yes" Text="[P_REMOVEB]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Verify repair ______________ -->
      <Dialog Id="MyVerifyRepairDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_VRP_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="60" Width="320" Height="40" NoPrefix="yes" Text="[P_VRP_DESC]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Repair" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" ElevationShield="yes" Text="[P_REPAIRB]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Maintenance welcome ______________ -->
      <Dialog Id="MyMaintWelcomeDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="Bitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="234" TabSkip="no" Text="WixUI_Bmp_Dialog" />
        <Control Id="Title" Type="Text" X="135" Y="20" Width="220" Height="60" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Bigger}[P_MW_TITLE]" />
        <Control Id="Description" Type="Text" X="135" Y="80" Width="220" Height="60" Transparent="yes" NoPrefix="yes" Text="[P_MW_DESC]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Disabled="yes" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Maintenance type ______________ -->
      <Dialog Id="MyMaintTypeDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_MT_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="[P_MT_DESC]" />
        <Control Id="RepairButton" Type="PushButton" X="40" Y="65" Width="80" Height="17" Text="[P_REPAIRB]" />
        <Control Id="RepairText" Type="Text" X="60" Y="85" Width="280" Height="24" NoPrefix="yes" Text="[P_MT_REPAIR_DESC]" />
        <Control Id="RemoveButton" Type="PushButton" X="40" Y="118" Width="80" Height="17" Text="[P_REMOVEB]" />
        <Control Id="RemoveText" Type="Text" X="60" Y="138" Width="280" Height="24" NoPrefix="yes" Text="[P_MT_REMOVE_DESC]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Disabled="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Remove options (uninstall) ______________ -->
      <Dialog Id="RemoveOptionsDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_RO_TITLE]" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="[P_RO_DESC]" />
        <Control Id="Explain" Type="Text" X="25" Y="52" Width="320" Height="52" NoPrefix="yes" Text="[P_RO_EXPLAIN]" />
        <Control Id="GCloudCheck" Type="CheckBox" X="25" Y="110" Width="320" Height="17" Property="REMOVE_GCLOUD" CheckBoxValue="1" Text="[P_RO_GCLOUD]" />
        <Control Id="GCloudNote" Type="Text" X="37" Y="128" Width="308" Height="20" NoPrefix="yes" Text="{\WixUI_Font_Small}[P_RO_GCLOUD_NOTE]" />
        <Control Id="DataNote" Type="Text" X="25" Y="156" Width="320" Height="40" NoPrefix="yes" Text="[P_RO_DATA]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Progress ______________ -->
      <Dialog Id="MyProgressDlg" Width="370" Height="270" Title="[ProductName]" Modeless="yes">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="280" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}[P_PROG_TITLE]" />
        <Control Id="WaitText" Type="Text" X="25" Y="65" Width="320" Height="30" NoPrefix="yes" Text="[P_PROG_WAIT]" />
        <Control Id="StatusLabel" Type="Text" X="25" Y="100" Width="50" Height="10" NoPrefix="yes" Text="[P_PROG_STATUS]" />
        <Control Id="ActionText" Type="Text" X="75" Y="100" Width="280" Height="10">
          <Subscribe Event="ActionText" Attribute="Text" />
        </Control>
        <Control Id="ProgressBar" Type="ProgressBar" X="25" Y="115" Width="320" Height="10" ProgressBlocks="yes" Text="Progress done">
          <Subscribe Event="SetProgress" Attribute="Progress" />
        </Control>
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Disabled="yes" Text="[P_BACK]" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Disabled="yes" Text="[P_NEXT]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="[P_CANCELB]">
          <Publish Event="SpawnDialog" Value="MyCancelDlg">1</Publish>
        </Control>
      </Dialog>

      <!-- ______________ Exit ______________ -->
      <Dialog Id="MyExitDlg" Width="370" Height="270" Title="[ProductName]">
        <Control Id="Bitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="234" TabSkip="no" Text="WixUI_Bmp_Dialog" />
        <Control Id="Title" Type="Text" X="135" Y="20" Width="220" Height="60" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Bigger}[P_EXIT_TITLE]" />
        <Control Id="Description" Type="Text" X="135" Y="80" Width="220" Height="40" Transparent="yes" NoPrefix="yes" Text="[P_EXIT_DESC]" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Disabled="yes" Text="[P_BACK]" />
        <Control Id="Finish" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Cancel="yes" Text="[P_FINISH]" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Disabled="yes" Text="[P_CANCELB]" />
      </Dialog>

      <!-- ______________ Cancel confirmation ______________ -->
      <Dialog Id="MyCancelDlg" Width="260" Height="85" Title="[ProductName]">
        <Control Id="Text" Type="Text" X="48" Y="15" Width="194" Height="30" NoPrefix="yes" Text="[P_CANCEL_MSG]" />
        <Control Id="Icon" Type="Icon" X="15" Y="15" Width="24" Height="24" ToolTip="Information icon" FixedSize="yes" IconSize="32" Text="WixUI_Ico_Info" />
        <Control Id="No" Type="PushButton" X="132" Y="57" Width="56" Height="17" Default="yes" Cancel="yes" Text="[P_NO]">
          <Publish Event="EndDialog" Value="Return">1</Publish>
        </Control>
        <Control Id="Yes" Type="PushButton" X="72" Y="57" Width="56" Height="17" Text="[P_YES]">
          <Publish Event="EndDialog" Value="Exit">1</Publish>
        </Control>
      </Dialog>
    </UI>

    <UIRef Id="WixUI_Common" />

    <!-- Own dialog sequencing (the stock WixUI Welcome/Progress/Exit are not
         referenced, so their Show entries do not exist). -->
    <InstallUISequence>
      <Show Dialog="MyWelcomeDlg" After="CostFinalize">NOT Installed</Show>
      <Show Dialog="MyMaintWelcomeDlg" After="MyWelcomeDlg">Installed AND NOT RESUME AND NOT Preselected AND NOT PATCH</Show>
      <Show Dialog="MyProgressDlg" After="MyMaintWelcomeDlg">1</Show>
      <Show Dialog="MyExitDlg" OnExit="success" />
    </InstallUISequence>
  </Fragment>
</Wix>
