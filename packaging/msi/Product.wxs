<?xml version="1.0" encoding="UTF-8"?>
<!--
  MyOverlay MSI. Payload = the PyInstaller onedir build (dist\myoverlay,
  harvested by heat into HarvestedFiles.wxs at build time). The setup wizard
  (WizardUI.wxs) collects: output language, shortcut choices, Google API
  client secret (validated, skippable with a warning) and default render
  resolution; a deferred CA writes them to install_settings.json, which the
  launcher applies when it creates config.toml on first run.

  Build with packaging\msi\build_msi.ps1.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="MyOverlay - the definitive overlay tool for MyChron users"
           Language="1033"
           Version="0.1.0"
           Manufacturer="Rodrigo Brim"
           UpgradeCode="7C3B7A66-9A1E-4C1D-B7F1-52A70E6D0D11">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine"
             Description="MyOverlay setup" Platform="x64" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of MyOverlay is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Wizard choices. Secure: passed from the UI to the elevated execute
         sequence of this per-machine install. -->
    <Property Id="OUTPUT_LANGUAGE" Value="en" Secure="yes" />
    <Property Id="RESOLUTION" Value="2k" Secure="yes" />
    <Property Id="STARTMENU_SHORTCUT" Value="1" Secure="yes" />
    <Property Id="DESKTOP_SHORTCUT" Secure="yes" />
    <Property Id="GOOGLE_CLIENT_SECRET" Secure="yes" />
    <Property Id="GOOGLE_SKIPPED" Value="0" Secure="yes" />
    <!-- Uninstall always goes through the wizard (Programs and Features shows
         only 'Change'), so the remove-options page - with the gcloud checkbox
         - is always presented before uninstalling. -->
    <Property Id="ARPNOREMOVE" Value="1" />
    <Property Id="REMOVE_GCLOUD" Secure="yes" />

    <!-- Application icon (branding) for the shortcuts and the Programs and
         Features entry. -->
    <Icon Id="AppIcon.ico" SourceFile="../../assets/branding/app.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="MyOverlay">
          <!-- Offline Google Cloud SDK payload (harvested into GCloudFiles). -->
          <Directory Id="GCLOUDDIR" Name="google-cloud-sdk" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="MyOverlay" />
      </Directory>
      <Directory Id="DesktopFolder" />
    </Directory>

    <!-- Shortcuts run `myoverlay run` (the zero-touch workflow) in a console.
         Non-advertised, conditioned on the wizard checkboxes. -->
    <DirectoryRef Id="AppMenuFolder">
      <Component Id="StartMenuShortcut" Guid="10B3B9E4-63F2-4C89-9A57-2E24D8B10F01" Win64="yes">
        <Condition>STARTMENU_SHORTCUT = "1"</Condition>
        <Shortcut Id="StartMenuRun" Name="MyOverlay"
                  Description="The definitive overlay tool for MyChron users"
                  Target="[INSTALLFOLDER]myoverlay.exe" Arguments="run"
                  WorkingDirectory="INSTALLFOLDER" Icon="AppIcon.ico" />
        <RemoveFolder Id="RemoveAppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKLM" Key="Software\MyOverlay" Name="StartMenuShortcut"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="1B0B18A2-7B4B-45D3-8E19-6A4E2C33AB02" Win64="yes">
        <Condition>DESKTOP_SHORTCUT = "1"</Condition>
        <Shortcut Id="DesktopRun" Name="MyOverlay"
                  Description="The definitive overlay tool for MyChron users"
                  Target="[INSTALLFOLDER]myoverlay.exe" Arguments="run"
                  WorkingDirectory="INSTALLFOLDER" Icon="AppIcon.ico" />
        <RegistryValue Root="HKLM" Key="Software\MyOverlay" Name="DesktopShortcut"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="Main" Title="MyOverlay" Level="1" Absent="disallow" Display="hidden">
      <ComponentGroupRef Id="MyOverlayFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- The bundled SDK is its own feature so it can be conditionally skipped
         when the machine already has gcloud (Level 0 = not installed). When it
         IS installed, uninstalling MyOverlay removes it automatically. -->
    <Feature Id="GCloudSdk" Level="1" Absent="disallow" Display="hidden">
      <ComponentGroupRef Id="GCloudFiles" />
      <ComponentRef Id="GCloudPath" />
      <Condition Level="0">GCLOUD_PRESENT</Condition>
    </Feature>

    <!-- The offline SDK is bundled as MSI files (GCloudFiles component group,
         installed under GCLOUDDIR) and set up with install.bat in quiet mode.
         No download, no wizard, no clicks - the progress bar carries it. -->
    <!-- Set by AppSearch when the SDK is already on this machine: the SDK
         feature is then not installed and the wizard skips its page. Checks
         the per-user and per-machine uninstall registrations. -->
    <Property Id="GCLOUD_PRESENT" Secure="yes">
      <RegistrySearch Id="GCloudUserReg" Root="HKCU"
                      Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\Google Cloud SDK"
                      Name="UninstallString" Type="raw" />
      <RegistrySearch Id="GCloudMachineReg" Root="HKLM"
                      Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\Google Cloud SDK"
                      Name="UninstallString" Type="raw" Win64="no" />
    </Property>

    <!-- The extracted archive is a complete, working gcloud - no install.bat
         needed (running it popped a console, paused on a prompt, and could not
         update PATH anyway). We just put its bin on the machine PATH via MSI's
         own Environment table, which is silent and cleanly removed on
         uninstall. This component rides in the GCloudSdk feature, so PATH is
         only touched when we actually install the bundled SDK. -->
    <DirectoryRef Id="GCLOUDDIR">
      <Component Id="GCloudPath" Guid="3F8A9C21-4D0B-4E77-9B1A-7C6E5D2F0A44" Win64="yes">
        <CreateFolder />
        <Environment Id="GCloudBinPath" Name="PATH" Part="last" Action="set"
                     Permanent="no" System="yes" Value="[GCLOUDDIR]bin" />
        <RegistryValue Root="HKLM" Key="Software\MyOverlay" Name="GCloudPath"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Persist wizard choices next to the exe (elevated, after files land). -->
    <Binary Id="WriteSettingsJs" SourceFile="write_settings.js" />
    <CustomAction Id="WriteSettings.SetData" Property="WriteSettings"
                  Value="[INSTALLFOLDER]|[OUTPUT_LANGUAGE]|[RESOLUTION]|[GOOGLE_CLIENT_SECRET]|[GOOGLE_SKIPPED]" />
    <CustomAction Id="WriteSettings" BinaryKey="WriteSettingsJs"
                  JScriptCall="WriteSettings" Execute="deferred"
                  Impersonate="no" Return="ignore" />
    <!-- Preselect the wizard's language from the machine's UI language. -->
    <CustomAction Id="DetectLanguage" BinaryKey="WriteSettingsJs"
                  JScriptCall="DetectLanguage" Execute="immediate" Return="ignore" />
    <!-- Fill every P_* wizard string for the active language (generated file;
         see gen_i18n_ui.py). Runs before the first dialog and again from the
         language combo's Next/Back. -->
    <Binary Id="I18nUiJs" SourceFile="i18n_ui.js" />
    <CustomAction Id="ApplyUiLanguage" BinaryKey="I18nUiJs"
                  JScriptCall="ApplyUiLanguage" Execute="immediate" Return="ignore" />
    <!-- The settings file is created by a CA, so removal must be explicit. -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="SettingsCleanup" Guid="52D5B0C0-1F0E-4E7B-9C57-8E70A21F5C03" Win64="yes">
        <RemoveFile Id="RemoveInstallSettings" Name="install_settings.json" On="uninstall" />
        <RegistryValue Root="HKLM" Key="Software\MyOverlay" Name="Installed"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>
    <Feature Id="Cleanup" Level="1" Absent="disallow" Display="hidden">
      <ComponentRef Id="SettingsCleanup" />
    </Feature>

    <!-- Uninstall cleanup: wipe everything the software put on the machine
         (launcher clone/config/token under %LOCALAPPDATA%\myoverlay, and the
         Google Cloud SDK when the checkbox was ticked). The media library
         (videos/telemetry) is never touched. Skipped on major upgrades. -->
    <Binary Id="UninstallCleanupJs" SourceFile="uninstall_cleanup.js" />
    <CustomAction Id="RemoveAppData" BinaryKey="UninstallCleanupJs"
                  JScriptCall="RemoveAppData" Execute="deferred"
                  Impersonate="yes" Return="ignore" />
    <CustomAction Id="RemoveGCloud" BinaryKey="UninstallCleanupJs"
                  JScriptCall="RemoveGCloud" Execute="deferred"
                  Impersonate="yes" Return="ignore" />

    <!-- Detect before the wizard shows (UI) and before settings are written
         for a silent install (execute). -->
    <InstallUISequence>
      <!-- Unconditional: maintenance mode dialogs localize too. -->
      <Custom Action="DetectLanguage" After="AppSearch">1</Custom>
      <Custom Action="ApplyUiLanguage" After="DetectLanguage">1</Custom>
    </InstallUISequence>

    <InstallExecuteSequence>
      <!-- UILevel < 5: silent/basic installs only - with the full wizard the
           user's explicit combo choice must never be re-detected over. -->
      <Custom Action="DetectLanguage" After="AppSearch">NOT Installed AND UILevel &lt; 5</Custom>
      <Custom Action="WriteSettings.SetData" After="InstallFiles">NOT Installed</Custom>
      <Custom Action="WriteSettings" After="WriteSettings.SetData">NOT Installed</Custom>
      <Custom Action="RemoveGCloud" After="InstallInitialize">REMOVE="ALL" AND REMOVE_GCLOUD="1" AND NOT UPGRADINGPRODUCTCODE</Custom>
      <Custom Action="RemoveAppData" After="RemoveGCloud">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

    <UIRef Id="MyOverlayWizard" />
  </Product>
</Wix>
